# ============================================================
#  Cita Previa Extranjería — appointment monitor
#  Copy this file to .env and fill in your values
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
# Create a bot via @BotFather and get your chat ID via @userinfobot
BOT_TOKEN=
CHAT_ID=

# ── Your identity (used to fill the NIE form) ─────────────────
NIE=
NAME=
NATIONALITY=

# ── Appointment target ─────────────────────────────────────────
TARGET_PROVINCE=
TARGET_PROCEDURE_TEXT=

# ── Browser ────────────────────────────────────────────────────
HEADLESS=false
PAGE_TIMEOUT_MS=90000
MANUAL_ALLOW_WAIT_SECONDS=8

# ── Unknown-stage retry tuning (anti-bot/dynamic page readiness) ─────────
# Aggressive profile: higher retries and longer waits for delayed ICP pages.
UNKNOWN_STAGE_MAX_RETRIES=8
UNKNOWN_STAGE_RETRY_BASE_MS=6000
UNKNOWN_STAGE_RETRY_STEP_MS=3000
UNKNOWN_STAGE_RETRY_MAX_MS=20000

# ── Human-like timing ──────────────────────────────────────────
ACTION_DELAY_MIN_MS=800
ACTION_DELAY_MAX_MS=2200

# ── Monitor loop interval ──────────────────────────────────────
CHECK_INTERVAL_MIN_SECONDS=600
CHECK_INTERVAL_MAX_SECONDS=1800
BLOCK_BACKOFF_MIN_SECONDS=300
BLOCK_BACKOFF_MAX_SECONDS=900

# ── Duplicate alert suppression ────────────────────────────────
NOTIFY_COOLDOWN_SECONDS=3600
NOTIFY_ON_UNAVAILABLE=true
UNAVAILABLE_NOTIFY_COOLDOWN_SECONDS=3600

# ── Runtime mode ───────────────────────────────────────────────
RUN_ONCE=false
DRY_RUN=false

# ── Debug artifacts ────────────────────────────────────────────
SAVE_DEBUG_ARTIFACTS=true
DEBUG_ARTIFACTS_DIR=artifacts

# ── Custom proxy pool (optional) ──────────────────────────────
# Recommended for 10-20 proxies: one proxy per line in proxies.txt
PROXIES_FILE=proxies.txt
# Optional inline list (comma, semicolon, or newline separated)
PROXIES=
# ── Oxylabs Residential Proxies ───────────────────────────────
# Rotating every 2 tries
PROXY_ROTATE_EVERY=2
OXYLABS_ENABLED=false
OXYLABS_ENTRY=pr.oxylabs.io
OXYLABS_PORT=7777
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
OXYLABS_COUNTRY=ES
OXYLABS_CITY=barcelona
OXYLABS_STICKY_SESSION=true
OXYLABS_SESSION_TIME_MINUTES=10
